rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ──────────────────────────────────────────────
    function isAuth() { return request.auth != null; }
    function isMe(uid) { return request.auth.uid == uid; }

    // ── Users ──────────────────────────────────────────────
    match /users/{uid} {
      allow read: if isAuth();   // friends need to read profiles
      allow write: if isMe(uid); // only owner can write own profile

      // Private day logs
      match /logs/{logId} {
        allow read, write: if isMe(uid);

        match /clips/{clipId} {
          allow read, write: if isMe(uid);
        }
      }

      // Direct Snaps Inbox
      match /inbox/{snapId} {
        allow create: if isAuth();
        allow read, update, delete: if isMe(uid);
      }
    }

    // ── Friendships ──────────────────────────────────────────
    match /friendships/{docId} {
      // Any involved user can read
      allow read: if isAuth() && request.auth.uid in resource.data.users;
      // Create: requester must be the authenticated user
      allow create: if isAuth() && request.auth.uid in request.resource.data.users
                    && request.resource.data.requestedBy == request.auth.uid;
      // Update: only the OTHER user can accept (not the requester)
      allow update: if isAuth() && request.auth.uid in resource.data.users
                    && resource.data.requestedBy != request.auth.uid;
      // Delete: either user can remove
      allow delete: if isAuth() && request.auth.uid in resource.data.users;
    }

    // ── Groups ──────────────────────────────────────────────
    match /groups/{groupId} {
      allow read: if isAuth() && request.auth.uid in resource.data.members;
      allow create: if isAuth() && request.auth.uid in request.resource.data.members
                    && request.resource.data.createdBy == request.auth.uid;
      allow update: if isAuth() && request.auth.uid in resource.data.members;
      allow delete: if isAuth() && request.auth.uid in resource.data.members;
    }

    // ── Shared Logs ──────────────────────────────────────────
    match /sharedLogs/{shareId} {
      // Owner can always read/write
      // A listed viewer can read
      allow read: if isAuth() && (
        resource.data.ownerUid == request.auth.uid ||
        request.auth.uid in resource.data.viewers.keys()
      );
      // Only owner can create
      allow create: if isAuth() && (
        request.resource.data.ownerUid == request.auth.uid
      );
      
      // Allow viewers to update the doc (needed to mark as viewed or add reactions)
      allow update: if isAuth() && (
        request.resource.data.ownerUid == request.auth.uid || 
        (request.auth.uid in resource.data.viewers.keys())
      );
      allow delete: if isAuth() && resource.data.ownerUid == request.auth.uid;
    }

    // ── Reactions ──────────────────────────────────────────
    match /reactions/{shareId}/clips/{clipId}/reacts/{reactorUid} {
      // Owner of the log or a viewer can read reactions
      allow read: if isAuth();
      // Only the reactor can write their own reaction
      allow write: if isAuth() && request.auth.uid == reactorUid;
      allow delete: if isAuth() && request.auth.uid == reactorUid;
    }
    // ── Blocks ──────────────────────────────────────────────
    match /blocks/{blockId} {
      allow read: if isAuth() && request.auth.uid == resource.data.blocker;
      allow create: if isAuth() && request.auth.uid == request.resource.data.blocker;
      allow delete: if isAuth() && request.auth.uid == resource.data.blocker;
    }
  }
}
